{
  "name": "mustardtree-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create mustardtree-portal",
    "db:migrate": "wrangler d1 execute mustardtree-portal --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute mustardtree-portal --local --file=schema.sql",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.91.0"
  }
}
