# Environment Variables Template for MustardTree Partners
#
# Copy this file to .env.local for development
# Set these as environment variables in Cloudflare Pages for production

# ================================
# CLOUDFLARE ACCESS CONFIGURATION
# ================================

# Your Cloudflare Account ID (found in dashboard sidebar)
VITE_CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Cloudflare Access Application Audience (AUD) tag
# Found in Zero Trust > Access > Applications > Your App > Overview
VITE_CLOUDFLARE_ACCESS_APPLICATION_AUD=your_application_aud_here

# Your main domain for Cloudflare Access
VITE_DOMAIN=mustardtreegroup.com

# ================================
# API CONFIGURATION
# ================================

# Backend Worker API URL
# Development: leave empty (uses relative URLs proxied by Vite)
# Production: https://mustardtree-api.<your-subdomain>.workers.dev
VITE_API_BASE_URL=

# ================================
# APPLICATION CONFIGURATION
# ================================

# Application environment
NODE_ENV=production

# Document retention period (in days)
VITE_DOCUMENT_RETENTION_DAYS=2555  # 7 years

# ================================
# SECURITY CONFIGURATION
# ================================

# Enable audit logging
VITE_ENABLE_AUDIT_LOGGING=true

# Session timeout (in minutes)
VITE_SESSION_TIMEOUT=480  # 8 hours

# ================================
# DEVELOPMENT CONFIGURATION
# ================================

# Enable debug logging (development only)
VITE_DEBUG_MODE=false

# ================================
# OPTIONAL INTEGRATIONS
# ================================

# Analytics tracking ID (if using)
VITE_ANALYTICS_ID=

# Error reporting service (if using)
VITE_ERROR_REPORTING_DSN=

# ================================
# CLOUDFLARE PAGES DEPLOYMENT
# ================================

# These are set automatically in Cloudflare Pages
# CF_PAGES=1
# CF_PAGES_COMMIT_SHA=
# CF_PAGES_BRANCH=
# CF_PAGES_URL=

# ================================
# NOTE: R2 credentials are ONLY configured in the Worker backend
# (worker/wrangler.toml) via R2 bucket bindings.
# They are NEVER exposed to the frontend.
# ================================
